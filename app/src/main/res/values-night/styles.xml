<resources>

    <style name="AppTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorLightKnight</item>
        <item name="colorPrimaryDark">@color/colorDarkKnight</item>
        <item name="colorAccent">@color/colorTextWarningRed</item>
        <item name="android:windowBackground">@color/colorAccent_dark</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:textColorPrimary">@color/colorPrimaryText</item>
        <item name="android:navigationBarColor">@color/colorLightKnight</item>
    </style>

    <style name="DarkTheme_DarkSide" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorLightKnight</item>
        <item name="colorPrimaryDark">@color/colorDarkKnight</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="card_color">@color/colorLightKnight</item>
        <item name="drawer_color">@color/colorPrimaryText</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowBackground">@color/colorDarkKnight</item>
        <item name="android:textColorPrimary">@color/colorPrimaryText</item>
        <item name="android:navigationBarColor">@color/colorDarkKnight</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>

        <!-- Custom theme for Material Dialogs-->
        <item name="md_color_title">@color/colorTextTitle_dark</item>
        <item name="md_color_content">@color/colorTextContent_dark</item>
        <item name="md_color_button_text">@color/colorAccent</item>
        <item name="md_background_color">@color/colorDarkKnight</item>

        <!-- Force time picker dialog to use spinner mode -->
        <item name="android:timePickerMode">spinner</item>
        <item name="android:timePickerStyle">@style/TTSTimeStopPicker</item>
    </style>

    <style name="AppImagePreview" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/colorDarkKnight</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
    </style>

    <!-- Material3 Bottom Sheet theme for Compose-hosted bottom sheets (dark) -->
    <style name="Theme_NovelLibrary_BottomSheet" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.NovelLibrary.BottomSheet</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.NovelLibrary.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

</resources>
